@model IEnumerable<Sapatus.Models.Produto>
@{
    ViewData["Title"] = "Loja";
    var categorias = ViewBag.Categorias as string[] ?? Array.Empty<string>();
    var categoriaAtual = ViewBag.CategoriaAtual as string;
    var searchTerm = ViewBag.SearchTerm as string;
}

<!-- Page Header -->
<section class="bg-gradient-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="mb-2">
                    <i class="fas fa-store me-2"></i>Nossa Loja
                </h1>
                <p class="mb-0 opacity-75">Encontra o par perfeito para ti</p>
            </div>
            <div class="col-md-4">
                <form asp-action="Index" method="get" class="d-flex">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control" placeholder="Pesquisar produtos..." value="@searchTerm">
                        <button type="submit" class="btn btn-light">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="section">
    <div class="container">
        <!-- Category Filter -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-2 justify-content-center">
                    <a asp-action="Index" class="btn @(categoriaAtual == null ? "btn-primary" : "btn-outline-primary")">
                        Todos
                    </a>
                    @foreach (var cat in categorias)
                    {
                        <a asp-action="Index" asp-route-categoria="@cat" class="btn @(categoriaAtual == cat ? "btn-primary" : "btn-outline-primary")">
                            @cat
                        </a>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <div class="alert alert-info mb-4">
                <i class="fas fa-search me-2"></i>Resultados para: <strong>@searchTerm</strong>
                <a asp-action="Index" class="float-end"><i class="fas fa-times"></i> Limpar</a>
            </div>
        }

        <!-- Products Grid -->
        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var produto in Model)
                {
                    var stockTotal = produto.Stocks?.Sum(s => s.Quantidade) ?? 0;
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="card card-product h-100">
                            <div class="card-img-wrapper">
                                <span class="badge-category">@produto.Categoria</span>
                                @if (produto.EmDestaque)
                                {
                                    <span class="badge bg-warning position-absolute" style="top: 10px; right: 10px; z-index: 2;">
                                        <i class="fas fa-star me-1"></i>Destaque
                                    </span>
                                }
                                <img src="@produto.ImagemUrl" class="card-img-top" alt="@produto.Nome" loading="lazy">
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@produto.Nome</h5>
                                <p class="card-text flex-grow-1">@(produto.Descricao?.Length > 60 ? produto.Descricao.Substring(0, 60) + "..." : produto.Descricao)</p>
                                
                                <div class="mb-2">
                                    @if (stockTotal > 10)
                                    {
                                        <span class="stock-info">
                                            <i class="fas fa-check-circle"></i>Em stock
                                        </span>
                                    }
                                    else if (stockTotal > 0)
                                    {
                                        <span class="stock-info low">
                                            <i class="fas fa-exclamation-circle"></i>Últimas unidades
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="stock-info out">
                                            <i class="fas fa-times-circle"></i>Esgotado
                                        </span>
                                    }
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <span class="price">@produto.Preco.ToString("C")</span>
                                    <a asp-action="Details" asp-route-id="@produto.Id" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i>Ver
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-search"></i>
                <h4>Nenhum produto encontrado</h4>
                <p>Tenta pesquisar com termos diferentes ou navega por categoria.</p>
                <a asp-action="Index" class="btn btn-primary mt-3">
                    <i class="fas fa-arrow-left me-2"></i>Ver Todos os Produtos
                </a>
            </div>
        }
    </div>
</section>
