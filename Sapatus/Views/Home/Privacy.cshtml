@{
    ViewData["Title"] = "Política de Privacidade";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-soft rounded-xl">
                <div class="card-body p-5">
                    <h1 class="text-center mb-4">
                        <i class="fas fa-shield-alt text-primary me-2"></i>Política de Privacidade
                    </h1>
                    
                    <p class="lead text-muted text-center mb-5">A tua privacidade é importante para nós. Esta política explica como tratamos os teus dados.</p>
                    
                    <hr class="my-4">
                    
                    <h4 class="mb-3">1. Informações que Recolhemos</h4>
                    <p>Recolhemos as seguintes informações quando crias uma conta ou fazes uma compra:</p>
                    <ul class="list-unstyled ms-4">
                        <li><i class="fas fa-check text-success me-2"></i>Nome e apelido</li>
                        <li><i class="fas fa-check text-success me-2"></i>Endereço de email</li>
                        <li><i class="fas fa-check text-success me-2"></i>Morada de entrega</li>
                        <li><i class="fas fa-check text-success me-2"></i>Histórico de compras</li>
                    </ul>
                    
                    <h4 class="mb-3 mt-4">2. Como Utilizamos as Tuas Informações</h4>
                    <p>Utilizamos os teus dados para:</p>
                    <ul class="list-unstyled ms-4">
                        <li><i class="fas fa-check text-success me-2"></i>Processar as tuas encomendas</li>
                        <li><i class="fas fa-check text-success me-2"></i>Gerir a tua conta</li>
                        <li><i class="fas fa-check text-success me-2"></i>Enviar atualizações sobre as tuas compras</li>
                        <li><i class="fas fa-check text-success me-2"></i>Melhorar a nossa plataforma</li>
                    </ul>
                    
                    <h4 class="mb-3 mt-4">3. Segurança dos Dados</h4>
                    <p>Implementamos medidas de segurança adequadas para proteger os teus dados pessoais contra acesso não autorizado, alteração, divulgação ou destruição.</p>
                    
                    <h4 class="mb-3 mt-4">4. Os Teus Direitos</h4>
                    <p>Tens o direito de:</p>
                    <ul class="list-unstyled ms-4">
                        <li><i class="fas fa-check text-success me-2"></i>Aceder aos teus dados pessoais</li>
                        <li><i class="fas fa-check text-success me-2"></i>Corrigir dados incorretos</li>
                        <li><i class="fas fa-check text-success me-2"></i>Solicitar a eliminação dos teus dados</li>
                        <li><i class="fas fa-check text-success me-2"></i>Cancelar a tua conta</li>
                    </ul>
                    
                    <h4 class="mb-3 mt-4">5. Contacto</h4>
                    <p>Se tiveres alguma questão sobre a nossa política de privacidade, contacta-nos:</p>
                    <div class="alert alert-info">
                        <i class="fas fa-envelope me-2"></i>Email: privacidade@sapatus.pt<br>
                        <i class="fas fa-phone me-2"></i>Telefone: +351 210 000 000
                    </div>
                    
                    <hr class="my-4">
                    
                    <p class="text-muted text-center mb-0">Última atualização: @DateTime.Now.ToString("MMMM yyyy")</p>
                </div>
            </div>
        </div>
    </div>
</div>
